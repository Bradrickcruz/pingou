PINGOU_PORT=8080
PINGOU_LOG_LEVEL=debug
PINGOU_API_KEY=troca-por-uma-chave-segura
PINGOU_DATABASE_URL=./pingou.db

# Vite
VITE_API_URL=http://localhost:$PINGOU_PORT/api

# CORS: comma-separated list of allowed origins (empty = disabled in production)
# Example for local dev: PINGOU_CORS_ALLOWED_ORIGINS=http://localhost:5173
PINGOU_CORS_ALLOWED_ORIGINS=

# HTTP Checker: max redirects (default: 5)
PINGOU_MAX_REDIRECTS=5

# HTTP Checker: global timeout in seconds (default: 60)
PINGOU_GLOBAL_TIMEOUT=60
